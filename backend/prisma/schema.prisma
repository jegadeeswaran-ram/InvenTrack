generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  username  String   @unique
  password  String   // bcrypt hashed
  role      Role     @default(SALES)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  sales     Sale[]
}

enum Role {
  ADMIN
  SALES
}

model Product {
  id           Int        @id @default(autoincrement())
  name         String
  emoji        String     @default("🍦")
  imageUrl     String?
  sellingPrice Float      @default(0)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  purchases    Purchase[]
  sales        Sale[]
}

model Purchase {
  id           Int      @id @default(autoincrement())
  date         DateTime
  productId    Int
  product      Product  @relation(fields: [productId], references: [id])
  manufacturer String
  quantity     Float
  costPerUnit  Float
  totalCost    Float
  notes        String?
  createdAt    DateTime @default(now())
}

model Sale {
  id           Int      @id @default(autoincrement())
  date         DateTime
  productId    Int
  product      Product  @relation(fields: [productId], references: [id])
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  quantity     Float
  pricePerUnit Float
  totalRevenue Float
  avgCostUnit  Float    // copied from purchase avg at time of sale
  profit       Float    // (pricePerUnit - avgCostUnit) * quantity
  notes        String?
  createdAt    DateTime @default(now())
}
