generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SALES
  BRANCH_MANAGER
  TRUCK_SALES
}

enum SessionStatus {
  OPEN
  CLOSED
}

model Branch {
  id        Int            @id @default(autoincrement())
  name      String
  address   String?
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  users     User[]
  trucks    Truck[]
  sessions  TruckSession[]
}

model Truck {
  id        Int            @id @default(autoincrement())
  name      String
  plateNo   String?
  branchId  Int
  branch    Branch         @relation(fields: [branchId], references: [id])
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  sessions  TruckSession[]
}

model User {
  id        Int            @id @default(autoincrement())
  name      String
  username  String         @unique
  mobile    String?        @unique
  email     String         @default("")
  password  String
  photo     String?
  role      Role           @default(SALES)
  isActive  Boolean        @default(true)
  branchId  Int?
  branch    Branch?        @relation(fields: [branchId], references: [id])
  createdAt DateTime       @default(now())
  sales     Sale[]
  sessions  TruckSession[]
}

model Product {
  id              Int             @id @default(autoincrement())
  name            String
  emoji           String          @default("🍦")
  imageUrl        String?
  sellingPrice    Float           @default(0)
  costPerUnit     Float           @default(0)
  piecesPerPacket Int             @default(1)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  purchases       Purchase[]
  sales           Sale[]
  saleItems       TruckSaleItem[]
  closingStocks   ClosingStock[]
}

model Purchase {
  id           Int      @id @default(autoincrement())
  date         DateTime
  productId    Int
  product      Product  @relation(fields: [productId], references: [id])
  manufacturer String   @default("")
  quantity     Float
  costPerUnit  Float
  totalCost    Float
  notes        String?
  createdAt    DateTime @default(now())
}

model Sale {
  id           Int      @id @default(autoincrement())
  date         DateTime
  productId    Int
  product      Product  @relation(fields: [productId], references: [id])
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  quantity     Float
  pricePerUnit Float
  totalRevenue Float
  avgCostUnit  Float
  profit       Float
  notes        String?
  createdAt    DateTime @default(now())
}

model TruckSession {
  id           Int            @id @default(autoincrement())
  userId       Int
  user         User           @relation(fields: [userId], references: [id])
  truckId      Int
  truck        Truck          @relation(fields: [truckId], references: [id])
  branchId     Int
  branch       Branch         @relation(fields: [branchId], references: [id])
  startTime    DateTime       @default(now())
  endTime      DateTime?
  status       SessionStatus  @default(OPEN)
  createdAt    DateTime       @default(now())
  sales        TruckSale[]
  closingStock ClosingStock[]
}

model TruckSale {
  id          Int             @id @default(autoincrement())
  sessionId   Int
  session     TruckSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  totalAmount Float
  timestamp   DateTime        @default(now())
  createdAt   DateTime        @default(now())
  items       TruckSaleItem[]
}

model TruckSaleItem {
  id        Int       @id @default(autoincrement())
  saleId    Int
  sale      TruckSale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId Int
  product   Product   @relation(fields: [productId], references: [id])
  quantity  Float
  price     Float
  total     Float
}

model ClosingStock {
  id         Int          @id @default(autoincrement())
  sessionId  Int
  session    TruckSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  productId  Int
  product    Product      @relation(fields: [productId], references: [id])
  soldQty    Float
  closingQty Float
  openingQty Float
  createdAt  DateTime     @default(now())

  @@unique([sessionId, productId])
}
