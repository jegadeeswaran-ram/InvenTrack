DATABASE_URL="postgresql://user:password@host:5432/kulfi_ice"
JWT_SECRET="your-super-secret-key-change-this-min-32-chars"
PORT=4000
NODE_ENV=development
WEB_ORIGIN="http://localhost:5173"
WEB_ORIGINS="https://your-web-domain.com,https://www.your-web-domain.com"
# Optional: set to * to allow any origin (insecure for public APIs). Code also treats * inside WEB_ORIGINS as allow-all.
CORS_ORIGIN="*"

# Railway/Object storage (S3-compatible bucket). If unset, files are stored locally in /uploads.
RAILWAY_BUCKET_NAME=""
RAILWAY_BUCKET_ENDPOINT=""
RAILWAY_BUCKET_REGION="auto"
RAILWAY_BUCKET_ACCESS_KEY_ID=""
RAILWAY_BUCKET_SECRET_ACCESS_KEY=""
# Most Railway/S3-compatible providers work with true.
RAILWAY_BUCKET_FORCE_PATH_STYLE=true
