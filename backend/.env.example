# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── PostgreSQL (Railway) ─────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:port/dbname?schema=public"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_min_32_chars_change_this_now
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_change_this_now
JWT_REFRESH_EXPIRES_IN=7d

# ─── S3-Compatible Storage (Railway Bucket) ───────────────────────────────────
S3_ENDPOINT=https://your-bucket-endpoint.railway.app
S3_REGION=us-east-1
S3_BUCKET=kulfi-uploads
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_PUBLIC_URL=https://your-public-bucket-url

# ─── Local Storage Fallback ───────────────────────────────────────────────────
# Set USE_LOCAL_STORAGE=true if S3 credentials are not configured
USE_LOCAL_STORAGE=false
LOCAL_UPLOAD_PATH=./uploads

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
WEB_ORIGINS=http://localhost:5173,http://localhost:5174
